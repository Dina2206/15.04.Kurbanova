<script>
    // Переключение между страницами
    const btnFestival = document.getElementById('btn-festival');
    const btnContest = document.getElementById('btn-contest');
    const pageFestival = document.getElementById('page-festival');
    const pageContest = document.getElementById('page-contest');

    function showFestival() {
        pageFestival.classList.add('active-page');
        pageContest.classList.remove('active-page');
        btnFestival.classList.add('active');
        btnContest.classList.remove('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showContest() {
        pageContest.classList.add('active-page');
        pageFestival.classList.remove('active-page');
        btnContest.classList.add('active');
        btnFestival.classList.remove('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    btnFestival.addEventListener('click', showFestival);
    btnContest.addEventListener('click', showContest);
</script>

